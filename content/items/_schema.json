{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ItemDefinition",
  "type": "object",
  "required": [
    "id",
    "displayNameKey",
    "descriptionKey",
    "slot",
    "rarity",
    "modelId",
    "modifiers",
    "requiredLevel"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "displayNameKey": { "type": "string", "minLength": 1 },
    "descriptionKey": { "type": "string", "minLength": 1 },
    "slot": { "enum": ["weapon", "armor", "accessory", "spirit"] },
    "rarity": { "enum": ["common", "uncommon", "rare", "epic", "legendary"] },
    "modelId": { "type": "string", "minLength": 1 },
    "modifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stat", "kind", "value"],
        "properties": {
          "stat": {
            "enum": ["hpMax", "manaMax", "atk", "def", "crit", "critDmg", "speed", "spirit"]
          },
          "kind": { "enum": ["flat", "percent"] },
          "value": { "type": "number" }
        }
      }
    },
    "requiredLevel": { "type": "integer", "minimum": 1 }
  }
}
