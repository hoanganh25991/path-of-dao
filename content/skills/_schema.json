{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Path of Dao Skill",
  "description": "Composable skill definition — see src/progression/SkillDefinition.ts for Zod source of truth",
  "type": "object",
  "required": ["id", "intent", "nameKey", "kind", "manaCost", "skillMultiplier"],
  "properties": {
    "id": { "type": "string" },
    "intent": { "enum": ["sword", "truth_falsehood", "flame", "lightning", "cause_effect", "life_death"] },
    "nameKey": { "type": "string" },
    "kind": { "enum": ["arc", "bolt", "heal", "meditate"] },
    "manaCost": { "type": "integer", "minimum": 0 },
    "skillMultiplier": { "type": "number", "exclusiveMinimum": 0 },
    "cooldownMs": { "type": "integer", "minimum": 1 },
    "castTimeMs": { "type": "integer", "minimum": 0 },
    "castFrameMs": { "type": "integer", "minimum": 0, "description": "Ms after cast trigger to fire cast-frame audio one-shot. Default 0 = immediate." },
    "impactFrameMs": { "type": "integer", "minimum": 0, "description": "Ms after cast trigger to fire impact-frame audio one-shot. Omit for kind-based default." },
    "effects": { "type": "array", "minItems": 1 },
    "vfx": {
      "type": "object",
      "properties": {
        "cast": { "type": "string" },
        "impact": { "type": "string" }
      }
    }
  }
}
