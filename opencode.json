{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek/deepseek-v4-pro:nitro",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "model": {
        "vision": "openrouter/google/gemini-2.5-flash"
      }
    }
  },
  "instructions": [".cursor/rules/graphify.mdc", ".cursor/rules/plan-track-updates.mdc"],
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 350000
    }
  }
}